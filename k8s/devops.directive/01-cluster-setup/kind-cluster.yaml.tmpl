# three note (2 workers) cluster
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
nodes:
  - role: control-plane
  - role: worker
    extraMounts:
      - hostPath: ${REPLACE_ABSOLUTE_PATH}/mount-node-1
        containerPath: /mnt/data
  - role: worker
    extraMounts:
      - hostPath: ${REPLACE_ABSOLUTE_PATH}/mount-node-2
        containerPath: /mnt/data